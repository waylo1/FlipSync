generator client {
  provider      = "prisma-client-js"
  // native = dev local (Windows/macOS) ; debian = image Docker de prod (node:20-slim).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet    UserWallet?
  listings  Listing[]
  draftJobs DraftJob[]
  missions  Mission[]
}

// ─── WALLET ───────────────────────────────────────────────────────────────────

model UserWallet {
  id                    String   @id @default(cuid())
  userId                String   @unique
  balance               Int      @default(0) // centimes — ex: 1000 = 10,00 €
  freeListingsRemaining Int      @default(3)
  freeListingsResetAt   DateTime @default(dbgenerated("NOW() + INTERVAL '1 month'"))
  autoRechargeEnabled   Boolean  @default(false)
  autoRechargeThreshold Int      @default(100) // centimes — ex: 100 = 1,00 €
  autoRechargeAmount    Int      @default(1000) // centimes — ex: 1000 = 10,00 €
  lifetimeRecharged     Int      @default(0) // centimes
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String          @id @default(cuid())
  walletId    String
  type        TransactionType
  amount      Int // centimes
  source      PaymentSource
  listingId   String?
  stripeId    String?         @unique // idempotence webhook : un event Stripe = max un crédit
  description String?
  createdAt   DateTime        @default(now())

  wallet  UserWallet @relation(fields: [walletId], references: [id])
  listing Listing?   @relation(fields: [listingId], references: [id])

  @@index([type, createdAt])
}

// ─── LISTING ──────────────────────────────────────────────────────────────────

model Listing {
  id            String        @id @default(cuid())
  userId        String
  tier          ListingTier
  status        ListingStatus @default(PENDING_AUTH)
  paymentSource PaymentSource
  cost          Int // centimes

  // Données IA
  titre           String?
  description     String?
  categorieId     String? // CanonicalCategoryId (référentiel versionné, ADR-010) — pas de colonne par canal
  etat            ItemCondition?
  prixPlancher    Int? // centimes
  prixHaut        Int? // centimes
  prixPublie      Int? // centimes — prix final choisi par l'utilisateur
  marque          String?
  confidence      Float? // score 0–1, pas de l'argent → Float intentionnel

  // Plateformes
  publishedLbc    Boolean @default(false)
  publishedVinted Boolean @default(false)
  lbcUrl          String?
  vintedUrl       String?

  // Diplomatie : true si prixPublie > prixHaut * 1.2
  isPriceFlagged Boolean @default(false)

  // Toujours renseigné sur AI_FAILED / PUBLISH_FAILED (cf. CLAUDE.md)
  failureReason String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  user         User                 @relation(fields: [userId], references: [id])
  photos       ListingPhoto[]
  transactions WalletTransaction[]
  mission      Mission?
  publications ListingPublication[]

  @@index([status, updatedAt])
}

// ─── PUBLICATION PAR PLATEFORME (Core Sync Engine, ADR-009) ───────────────────
// 1 ligne par annonce réellement créée chez une plateforme — l'externalId est
// la clé de toute opération ultérieure (update/withdraw/checkStatus). Créée
// UNIQUEMENT sur succès connecteur (Jeton Global : ≥1 ligne ⇒ PUBLISHED).
// Remplace à terme les colonnes legacy publishedLbc/publishedVinted/lbcUrl/vintedUrl.

model ListingPublication {
  id          String            @id @default(cuid())
  listingId   String
  marketplace Marketplace
  externalId  String
  url         String?
  status      PublicationStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, marketplace])
}

// ─── MISSION (Commissaire-Priseur IA) ──────────────────────────────────────────
// Cf. COMMISSAIRE_PRISEUR_PLAN.md §5.3/§10 Lot 3. Le mandat (posture, objectif,
// prix mini, livraison, cas complexes) est saisi côté mobile (S1→S3) puis
// persisté ici tel quel à la confirmation — champs stockés en String, les enums
// TS de @flipsync/core (SellPosture, SellObjective, DeliveryPreference,
// ComplexCasePolicy) restent la SEULE source de vérité des valeurs valides
// (validation Zod aux frontières API, pas de duplication en enum Prisma).
model Mission {
  id     String        @id @default(cuid())
  userId String
  status MissionStatus @default(BROUILLON_MANDAT)

  listingId String @unique

  posture                  String
  objectif                 String
  prixAffiche              Int // centimes
  prixMini                 Int // centimes
  livraison                String
  casComplexes             String
  autoAdjugeAuDessusDuMini Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  enVenteAt DateTime?
  soldAt    DateTime?

  // ─── Ardoise vivante du canal simulé (Lot 4/5) — dérivée des MissionEvent, ─────
  // jamais réécrite hors de MissionNegotiationService. Alimente le bandeau
  // d'état et la carte « en attente de vous » (S4) sans recalcul par requête.
  activeBuyerCount   Int            @default(0)
  bestOfferAmount    Int? // centimes — meilleure offre en cours, tous acheteurs confondus
  pendingReason      String? // 'OFFER' | 'OFFER_AT_FLOOR' | 'COMPLEX_CASE' | 'SECURITY_ALERT' (NegotiationAction)
  pendingOfferAmount Int? // centimes — présent si pendingReason ∈ {OFFER, OFFER_AT_FLOOR}
  pendingBuyerName   String?
  soldAmount         Int? // centimes
  preSuspendStatus   MissionStatus? // statut à restaurer par RESUMED, écrit en entrant dans SUSPENDUE
  lastNotifiedAt     DateTime? // anti-spam §7 : dernière notif de négociation envoyée (VALIDATION_REQUIRED/SECURITY_ALERT)

  user    User           @relation(fields: [userId], references: [id])
  listing Listing        @relation(fields: [listingId], references: [id])
  events  MissionEvent[]

  @@index([userId, status])
}

// ─── TIMELINE DE LA MISSION (S4, §5.4) ─────────────────────────────────────────
// 1 ligne par événement du canal simulé (Lot 4) — jamais réécrite, purement
// additive. kind reprend les types NegotiationAction / MissionEvent (core) en
// String (même décision SSOT que Mission : validation Zod à la frontière, pas
// de duplication en enum Prisma).
model MissionEvent {
  id        String   @id @default(cuid())
  missionId String
  kind      String
  summary   String
  amount    Int? // centimes, si l'événement porte un montant
  buyerName String?
  createdAt DateTime @default(now())

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId, createdAt])
}

// ─── IA — brouillon en job détaché ─────────────────────────────────────────────
// Cycle de vie DÉCOUPLÉ du modèle Listing (cf. CLAUDE.md Sprint 4) : pure
// génération de texte, aucun débit wallet, aucune transition ListingStatus ici.

model DraftJob {
  id        String         @id @default(uuid())
  userId    String
  status    DraftJobStatus @default(RUNNING)
  draft     Json?
  errorCode String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([status, updatedAt])
}

// ─── AUTH (magic link) ──────────────────────────────────────────────────────

model MagicLinkToken {
  id         String    @id @default(cuid())
  email      String
  tokenHash  String    @unique // sha256 du token brut — le brut n'est JAMAIS stocké
  expiresAt  DateTime
  consumedAt DateTime? // usage unique : renseigné à la vérification
  createdAt  DateTime  @default(now())

  @@index([email])
}

// ─── NOTIFICATIONS PUSH (§7) ────────────────────────────────────────────────────
// 1 ligne par device Expo enregistré — un user peut avoir plusieurs appareils.
// Pas de relation Prisma vers User (cohérent avec MagicLinkToken) : userId brut,
// suffisant pour le seul usage (lookup en envoi de notification).

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique // ExponentPushToken[...]
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── LISTING ──────────────────────────────────────────────────────────────────

model ListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  url       String
  order     Int      @default(0)
  sha256    String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum ListingTier {
  SIMPLE
  OPTIMIZED
  PREMIUM
}

enum ListingStatus {
  PENDING_AUTH // 1. Vérification des droits de paiement
  AUTHORIZED // 2. Autorisation accordée (pré-réservation, pas de débit)
  AI_PROCESSING // 3. Vision + rédaction SEO en cours
  AI_FAILED // 4. Échec du traitement IA (rollback, pas de débit)
  DRAFT_READY // 5. Brouillon prêt, en attente de validation utilisateur
  USER_VALIDATED // 6. Utilisateur a validé → commit() déclenché ici
  USER_CANCELLED // 7. Utilisateur a annulé (rollback, pas de débit)
  QUEUED // 8. En file d'attente pour publication
  PUBLISH_FAILED // 9. Échec de publication sur marketplace (remboursement)
  PUBLISHED // 10. Publié avec succès
  EXPIRED // 11. Annonce expirée sans vente
}

enum PaymentSource {
  FREE_CREDIT // Listing gratuit (crédit d'inscription ou promotion)
  WALLET // Débit depuis le wallet interne
  BLOCKED // Fonds insuffisants, publication bloquée
  STRIPE_RECHARGE // Rechargement Stripe (crédit wallet, jamais débit listing direct)
  BONUS // Bonus fidélité (ex: +1,00 € première recharge)
}

enum TransactionType {
  CREDIT
  DEBIT
  BONUS
  REFUND
}

enum DraftJobStatus {
  RUNNING
  READY
  FAILED
}

// Plateformes de revente (Core Sync Engine, ADR-009). SSOT Prisma (ADR-007) :
// générée dans packages/core/src/generated/enums.ts, ré-exportée par
// core/types/marketplace.ts — l'ancienne définition manuelle core disparaît.
// EBAY/SHOPIFY : connecteurs bouchonnés tant que les credentials manquent.
enum Marketplace {
  LEBONCOIN
  VINTED
  EBAY
  SHOPIFY
}

// Cycle de vie d'une publication PAR plateforme (anti-double-vente, Run 5).
// SOLD / WITHDRAWN = faits terminaux ; WITHDRAW_FAILED = actionnable (le
// webhook /webhooks/vendu re-tente le retrait à chaque rejeu). Le statut
// agrégé du Listing reste dérivé — jamais stocké (doctrine « une seule FSM »).
enum PublicationStatus {
  ACTIVE
  SOLD
  WITHDRAWN
  WITHDRAW_FAILED
}

enum ItemCondition {
  neuf
  tres_bon
  bon
  correct
}

// Cycle de vie d'une Mission de vente (palier Premium — Commissaire-Priseur IA).
// Cf. COMMISSAIRE_PRISEUR_PLAN.md §6. Le modèle Mission arrive au Lot 3 ; l'enum
// est déclaré dès le Lot 0 car il est la source de vérité des états côté TS
// (généré dans packages/core/src/generated/enums.ts).
enum MissionStatus {
  BROUILLON_MANDAT // Mandat en cours de configuration (S1→S3), non publié
  EN_VENTE // Annonce en ligne, l'IA veille
  NEGOCIATION_ACTIVE // Au moins un acheteur en discussion
  EN_ATTENTE_VALIDATION // L'IA a besoin du feu vert humain (S5)
  VENDU // Vente conclue (humain ou zéro-clic)
  MISSION_TERMINEE // Clôturée (après vente ou arrêt)
  SUSPENDUE // Mise en pause par le vendeur (réversible)
  ARRETEE // Vendeur a arrêté l'IA ; vente redevient manuelle
  EXPIREE // Délai plateforme atteint sans vente
}

// ─── DEV SESSIONS (Developer Control Center) ───────────────────────────────────
// Capacité générique de diagnostic dev — aucune FK vers User/Listing, réutilisable
// telle quelle hors FlipSync. Jamais actif en production (cf. routes dev-sessions).
//
// `DevEvent.type` est volontairement un String libre (pas d'enum Prisma) : la
// liste des types d'événements doit rester extensible sans migration (ajouter
// "performance", "websocket", etc. = juste étendre le schéma Zod côté app).
// L'intégrité est garantie à l'ingestion (Zod), pas au niveau DB.

model DevSession {
  id         String    @id @default(cuid())
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  platform   String? // ex: "android", "ios"
  appVersion String?

  events DevEvent[]

  @@index([startedAt])
}

model DevEvent {
  id        String   @id @default(cuid())
  sessionId String
  type      String // libre — cf. DEV_EVENT_TYPES (packages/core), pas d'enum DB
  ts        DateTime @default(now())
  payload   Json // forme dépend de `type` — cf. DevSessionEvent (packages/core)

  session DevSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, ts])
}
