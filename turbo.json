{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env",
    "packages/db/prisma/schema.prisma"
  ],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "DIRECT_URL",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "JWT_SECRET",
    "API_PORT",
    "API_HOST",
    "OLLAMA_BASE_URL",
    "OLLAMA_MODEL",
    "ADMIN_EMAILS",
    "MARKETPLACE_MOCK",
    "VINTED_ACCESS_TOKEN",
    "LEBONCOIN_ACCESS_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".expo/**"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": [
        "build"
      ]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": [
        "^build"
      ]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "persistent": true,
      "cache": false
    },
    "test:db": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    }
  }
}
