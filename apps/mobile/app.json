{
  "expo": {
    "name": "FlipSync",
    "slug": "flipsync",
    "scheme": "flipsync",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#FAF9F7"
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "maximepro",
    "runtimeVersion": "0.1.0-dev.1",
    "updates": {
      "url": "https://u.expo.dev/6ccf8b96-12e7-4dcc-83d3-5b7282a372c5",
      "fallbackToCacheTimeout": 0
    },
    "android": {
      "package": "fr.flipsync.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B8542F"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "ios": {
      "bundleIdentifier": "fr.flipsync.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "FlipSync utilise la caméra pour photographier vos objets à vendre."
      }
    },
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "FlipSync utilise la caméra pour photographier vos objets à vendre.",
          "enableMicrophonePermission": false
        }
      ],
      "expo-updates",
      [
        "expo-notifications",
        {
          "color": "#B8542F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6ccf8b96-12e7-4dcc-83d3-5b7282a372c5"
      }
    }
  }
}
