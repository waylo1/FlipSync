# ─── Supabase (PostgreSQL EU) ──────────────────────────────────────────────────
# DATABASE_URL : connexion poolée (pgBouncer) utilisée par l'app
# DIRECT_URL   : connexion directe utilisée par Prisma Migrate / db push
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Stripe attend des centimes nativement — pas de conversion côté app
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── IA côté serveur ───────────────────────────────────────────────────────────
# Pivot ADR-003 : l'inférence tourne côté API, jamais sur le mobile.
#
# Backend : "ollama" (dev, modèle local) | "anthropic" (prod, API hébergée).
# Non renseigné → anthropic si ANTHROPIC_API_KEY est posée, sinon ollama.
# Ollama est REFUSÉ en production (il n'existe pas dans l'image Docker).
AI_VISION_BACKEND=""

# Dev — Ollama sur le PC. 127.0.0.1 et non localhost : ::1 résout d'abord sur
# certaines machines Windows et le backend part en timeout.
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen2.5vl:3b"

# Prod — API Anthropic (~0,5 c€/annonce, cf. CLAUDE.md Sprint 4).
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# ─── API Fastify ───────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
# JWT_SECRET : minimum 32 caractères aléatoires en production
JWT_SECRET="change-me-in-production-min-32-characters"

# ─── Auth magic link ─────────────────────────────────────────────────────────
# TTL du lien (minutes) et base du lien envoyé (deep link app ou page web).
MAGIC_LINK_TTL_MINUTES=15
MAGIC_LINK_REDIRECT_URL="flipsync://auth/verify"
# Email transactionnel (prod) — si absents, fallback console (dev) qui logge le lien.
EMAIL_API_KEY=""
EMAIL_FROM="FlipSync <login@flipsync.fr>"

# ─── Publication marketplace (APIs partenaires officielles) ──────────────────
# Credentials fournis à l'onboarding partenaire (Vinted Integrations / LBC
# Partenaire — programmes sous contrat, pas de self-serve). Absents ou expirés →
# publication PUBLISH_FAILED + remboursement auto (jamais de faux succès) ;
# état visible sur GET /marketplace/status et le dashboard admin.
VINTED_ACCESS_TOKEN=""
LEBONCOIN_ACCESS_TOKEN=""
# Expiration optionnelle des tokens (date ISO, ex: 2026-12-31T00:00:00Z) —
# passée → état EXPIRED, le token n'est plus jamais envoyé à la plateforme.
VINTED_TOKEN_EXPIRES_AT=""
LEBONCOIN_TOKEN_EXPIRES_AT=""
MARKETPLACE_SELLER_ID=""
PUBLIC_BASE_URL="http://localhost:3001"
# Dev uniquement : 1 = connecteurs simulés (MockMarketplacePublisher) — jamais en prod.
MARKETPLACE_MOCK=0

# ─── Sécurité API ──────────────────────────────────────────────────────────────
# CORS : origines web autorisées, séparées par des virgules. Vide = tout accepté
# hors production, tout refusé en production (le mobile natif n'est pas concerné).
CORS_ORIGINS=""
# Rate limit /auth/* (req/min/IP). Défaut 5 — ne monter que pour les tests.
AUTH_RATE_LIMIT_MAX=5
# Derrière un reverse proxy (prod) : 1 pour lire l'IP client via X-Forwarded-For.
TRUST_PROXY=0

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
